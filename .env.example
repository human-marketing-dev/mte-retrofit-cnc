# Brevo transactional email — used by app/api/lead/route.ts to notify sales of
# a new lead. Server-only; never prefixed NEXT_PUBLIC_, so it is not exposed to
# the browser. Copy this file to .env.local and fill in the real key.
#
#   cp .env.example .env.local
#
# Get the key from Brevo → SMTP & API → API Keys.
BREVO_API_KEY=
